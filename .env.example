# Auxlo Configuration
# Copy to .env and fill in your values

# NVIDIA API (required)
NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model (optional, defaults to stepfun-ai/step-3.5-flash)
AUXLO_MODEL=stepfun-ai/step-3.5-flash

# Workspace path (optional)
AUXLO_WORKSPACE=/home/workspace/auxlo/auxlo_agent
